# Database
DATABASE_URL=postgresql://devfoundry:devfoundry@localhost:5432/devfoundry
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=devfoundry
DATABASE_PASSWORD=devfoundry
DATABASE_NAME=devfoundry

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API
API_PORT=3000
API_HOST=0.0.0.0
API_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GitHub
GITHUB_TOKEN=your-github-token-here
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Web
WEB_PORT=5173
VITE_API_URL=http://localhost:3000

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=devfoundry-api

# Feature Flags
ENABLE_MOCK_AGENTS=false
