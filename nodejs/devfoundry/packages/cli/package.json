{
  "name": "@devfoundry/cli",
  "version": "1.0.0",
  "description": "DevFoundry CLI",
  "main": "dist/index.js",
  "bin": {
    "devfoundry": "./bin/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "oclif": {
    "bin": "devfoundry",
    "dirname": "devfoundry",
    "commands": "./dist/commands",
    "plugins": []
  }
}
